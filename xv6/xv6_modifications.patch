+  printf("=== SCHEDULER PERFORMANCE TEST ===\n");
+  printf("Start time: %d ticks\n", start_time);
+  printf("Creating %d processes (%d IO-bound, %d CPU-bound)\n", NFORK, IO, NFORK-IO);
