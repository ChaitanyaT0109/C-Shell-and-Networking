+// Helper function to count runnable processes
+static int __attribute__((unused))
+count_runnable(void)
+{
+  struct proc *p;
+  int count = 0;
+  
+  for(p = proc; p < &proc[NPROC]; p++) {
+    if(p->state == RUNNABLE) {
+      count++;
+    }
+  }
+  
+  return count;
+}
