+// Helper function for CFS weight calculation
+static uint64 __attribute__((unused))
+calculate_weight(int nice)
+{
+  uint64 weight = 1024;
+  int i;
+  
+  if(nice > 0) {
+    for(i = 0; i < nice && i < 20; i++) {
+      weight = (weight * 4) / 5;
+    }
+  } else if(nice < 0) {
+    for(i = 0; i > nice && i > -20; i--) {
+      weight = (weight * 5) / 4;
+    }
+  }
+  
+  return weight > 0 ? weight : 1;
+}
