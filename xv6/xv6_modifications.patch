+      if (n < IO) {
+        printf("Process %d (PID %d): IO-bound starting at %d ticks\n", n, getpid(), child_start);
+        pause(200); // IO-bound process
+        printf("Process %d (PID %d): IO-bound finished at %d ticks (wait time: %d)\n", 
+               n, getpid(), uptime(), uptime() - child_start);
+      } else {
+        printf("Process %d (PID %d): CPU-bound starting at %d ticks\n", n, getpid(), child_start);
+        // CPU-bound process with progress tracking
+        for (volatile int i = 0; i < 1000000000; i++) {
+          if (i % 100000000 == 0 && i > 0) {
+            printf("Process %d (PID %d): CPU progress %d%% at %d ticks\n", 
+                   n, getpid(), i/10000000, uptime());
+          }
+        }
+        printf("Process %d (PID %d): CPU-bound finished at %d ticks (run time: %d)\n", 
+               n, getpid(), uptime(), uptime() - child_start);
+      }
+      exit(0);
+    }
+  }
+  
+  // Wait for all children and collect timing info
+  int completion_count = 0;
+  for (n = 0; n < NFORK; n++) {
+    wait(0);
+    completion_count++;
+    printf("Parent: %d/%d processes completed at %d ticks\n", 
+           completion_count, NFORK, uptime());
+  }
+  
+  int end_time = uptime();
+  printf("=== TEST COMPLETED ===\n");
+  printf("Total execution time: %d ticks\n", end_time - start_time);
+  printf("Average time per process: %d ticks\n", (end_time - start_time) / NFORK);
+  
+  exit(0);
+}
